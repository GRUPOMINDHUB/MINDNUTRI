# ── ANTHROPIC (Claude) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-COLOQUE_SUA_CHAVE_AQUI

# ── OPENAI (Whisper - transcrição de áudio) ───────────────────────
OPENAI_API_KEY=sk-COLOQUE_SUA_CHAVE_AQUI

# ── EVOLUTION API (WhatsApp) ──────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=COLOQUE_SUA_CHAVE_AQUI
EVOLUTION_INSTANCE=mindnutri

# ── ASAAS (pagamentos) ────────────────────────────────────────────
ASAAS_API_KEY=COLOQUE_SUA_CHAVE_AQUI
ASAAS_ENV=sandbox
# Troque para: https://api.asaas.com/v3  em produção
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ── DJANGO / PAINEL ───────────────────────────────────────────────
DJANGO_SECRET_KEY=mindnutri-chave-secreta-troque-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=grupomindhub.com.br,www.grupomindhub.com.br,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://grupomindhub.com.br,https://www.grupomindhub.com.br,http://localhost,http://127.0.0.1
DJANGO_FORCE_SCRIPT_NAME=

# ── STORAGE (onde ficam os arquivos gerados) ──────────────────────
# Para testes locais, os arquivos ficam numa pasta local
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./arquivos_gerados

# ── WHATSAPP DO GESTOR (para alertas) ────────────────────────────
GESTOR_WHATSAPP=5511999999999

# ── PLANO ─────────────────────────────────────────────────────────
PLANO_VALOR=89.90
PLANO_FICHAS_LIMITE=30

# SUPERUSUARIO DJANGO (opcional em producao)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@grupomindhub.com.br
DJANGO_SUPERUSER_PASSWORD=troque-esta-senha
